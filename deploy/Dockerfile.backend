# 构建阶段
FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY tsconfig.json ./tsconfig.orig.json
COPY src ./src

# 构建：临时修改 outDir 为容器内路径
RUN sed 's|"outDir": "../../prod/backend/dist"|"outDir": "./dist"|' tsconfig.orig.json > tsconfig.json && \
    npm run build

# 运行阶段
FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci --only=production

COPY --from=builder /app/dist ./dist

ENV NODE_ENV=production

EXPOSE 8000

CMD ["node", "dist/app.js"]
